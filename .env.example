# ═══════════════════════════════════════════════════════
# YOUTUBE TRANSCRIPT SUMMARIZER — Environment Variables
# ═══════════════════════════════════════════════════════

# ── Obbligatoria ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── OAuth2 Google (STRATEGIA PRIMARIA — consigliata) ──
# 1. Estrai client_id e client_secret dal tuo client_secret.json
# 2. Visita https://connect-my-code.vercel.app/api/auth
# 3. Autorizza l'app → copia il GOOGLE_REFRESH_TOKEN mostrato
# 4. In Google Console → OAuth 2.0 → Redirect URI aggiungi:
#    https://connect-my-code.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...   # ottienilo visitando /api/auth dopo il deploy

# ── Supadata (alternativa gratuita) ──────────────────
# Registrati su supadata.ai e copia la API key
SUPADATA_API_KEY=supa_...

# ── YouTube Data API v3 (supplementare) ──────────────
YOUTUBE_API_KEY=AIzaSy...

# ── Opzionali ─────────────────────────────────────────
AI_MODEL=google/gemini-2.0-pro-exp-02-05:free
SITE_URL=https://connect-my-code.vercel.app

# Database Neon
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

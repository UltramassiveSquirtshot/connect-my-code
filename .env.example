# Obbligatoria
OPENROUTER_API_KEY=sk-or-...

# YouTube Data API v3 — RICHIESTA per funzionare da IP datacenter (Vercel)
# Crea su https://console.cloud.google.com → API e servizi → YouTube Data API v3
# Senza questa chiave YouTube blocca le richieste con "Sign in to confirm you're not a bot"
YOUTUBE_API_KEY=AIzaSy...

# Opzionale — default: google/gemini-2.0-pro-exp-02-05:free
AI_MODEL=google/gemini-2.0-pro-exp-02-05:free

# Opzionale — usato come HTTP-Referer nelle chiamate OpenRouter
SITE_URL=https://connect-my-code.vercel.app

# Database Neon (opzionale — senza DB l'app funziona lo stesso)
# Usa DATABASE_URL o POSTGRES_URL (env var nativa Vercel Neon integration)
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
# oppure: POSTGRES_URL=...

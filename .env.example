# Obbligatoria
OPENROUTER_API_KEY=sk-or-...

# Opzionale — default: google/gemini-2.0-pro-exp-02-05:free
AI_MODEL=google/gemini-2.0-pro-exp-02-05:free

# Opzionale — usato come HTTP-Referer nelle chiamate OpenRouter
SITE_URL=https://connect-my-code.vercel.app

# Database Neon (opzionale — senza DB l'app funziona lo stesso)
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require

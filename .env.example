# ═══════════════════════════════════════════════════
# YOUTUBE TRANSCRIPT SUMMARIZER — Environment Variables
# ═══════════════════════════════════════════════════

# ── Obbligatoria ──────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Transcript YouTube ───────────────────────────
# Supadata (CONSIGLIATA): registrati gratis su supadata.ai
# Il free tier è sufficiente per uso normale.
# Senza questa key, il recupero sottotitoli da Vercel fallisce
# perché YouTube blocca le richieste da IP datacenter (AWS).
SUPADATA_API_KEY=supa_...

# YouTube Data API v3 (supplementare)
# Da Google Console → Abilita "YouTube Data API v3"
YOUTUBE_API_KEY=AIzaSy...

# ── Opzionali ────────────────────────────────────
# Modello AI (default: google/gemini-2.0-pro-exp-02-05:free)
AI_MODEL=google/gemini-2.0-pro-exp-02-05:free

# URL del sito (usato come HTTP-Referer per OpenRouter)
SITE_URL=https://connect-my-code.vercel.app

# Database Neon — la connessione string la trovi su neon.tech
# In Vercel puoi usare DATABASE_URL oppure POSTGRES_URL
DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
